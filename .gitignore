# --- Секрети та конфігурація ---
# Найважливіший файл! Ніколи не додавайте його до Git.
# Він містить токен бота та паролі до бази даних.
.env

# --- Залежності та віртуальне оточення ---
# Папки з віртуальним оточенням, які містять сотні файлів
# і встановлюються індивідуально на кожній машині.
venv/
.venv/
env/
*/venv/
*/.venv/

# --- Кеш та скомпільовані файли Python ---
# Ці файли генеруються автоматично для прискорення роботи
# і не повинні бути частиною репозиторію.
__pycache__/
*.pyc
*.pyo
*.pyd
*~

# --- Файли IDE та редакторів коду ---
# Папки з налаштуваннями для конкретних редакторів коду,
# щоб не нав'язувати свої налаштування іншим розробникам.
.idea/
.vscode/

# --- Логи та згенеровані дані ---
# Ці файли та папки створюються під час роботи бота.
# Вони можуть містити чутливу інформацію та швидко рости в розмірах.
*.log
archives/
data.csv
data.xlsx
*.json
!mobile-app/package.json
!mobile-app/package-lock.json
!mobile-app/app.json
!mobile-app/tsconfig.json
!mobile-app/jest.config.js
.env.save
# Backup files
*.bak.*
*.pwa-backup
*.bak
uploads/

# --- Android Build Artifacts ---
# Файли, що генеруються під час збірки Android додатку.
android-app/.gradle/
android-app/build/
android-app/app/build/
android-app/local.properties
android-app/*.apk
android-app/app/release/
android-app/app/debug/
*.hprof

# --- Mobile App (React Native + Expo) ---
mobile-app/node_modules/
mobile-app/.expo/
mobile-app/dist/
mobile-app/android/
mobile-app/ios/
mobile-app/.env
mobile-app/*.apk
mobile-app/*.aab