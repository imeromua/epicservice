# --- Секрети та конфігурація ---
# Найважливіший файл! Ніколи не додавайте його до Git.
# Він містить токен бота та паролі до бази даних.
.env

# --- Залежності та віртуальне оточення ---
# Папки з віртуальним оточенням, які містять сотні файлів
# і встановлюються індивідуально на кожній машині.
venv/
.venv/
env/
*/venv/
*/.venv/

# --- Кеш та скомпільовані файли Python ---
# Ці файли генеруються автоматично для прискорення роботи
# і не повинні бути частиною репозиторію.
__pycache__/
*.pyc
*.pyo
*.pyd
*~

# --- Файли IDE та редакторів коду ---
# Папки з налаштуваннями для конкретних редакторів коду,
# щоб не нав'язувати свої налаштування іншим розробникам.
.idea/
.vscode/

# --- Логи та згенеровані дані ---
# Ці файли та папки створюються під час роботи бота.
# Вони можуть містити чутливу інформацію та швидко рости в розмірах.
*.log
archives/
data.csv
data.xlsx
*.json
!mobile-app/package.json
!mobile-app/tsconfig.json
!mobile-app/app.json
.env.save
# Backup files
*.bak.*
*.pwa-backup
*.bak
uploads/

# --- Android Build Artifacts ---
# Файли, що генеруються під час збірки Android додатку.
android-app/.gradle/
android-app/build/
android-app/app/build/
android-app/local.properties
android-app/*.apk
android-app/app/release/
android-app/app/debug/
*.hprof

# --- Mobile App (React Native / Expo) ---
mobile-app/node_modules/
mobile-app/.expo/
mobile-app/dist/
mobile-app/ios/
mobile-app/android/
mobile-app/.env
mobile-app/web-build/
# --- Android Capacitor App ---
android-app/node_modules/
android-app/android/.gradle/
android-app/android/build/
android-app/android/app/build/
android-app/android/local.properties
android-app/android/app/release/
android-app/android/.idea/
android-app/android/captures/
android-app/android/.externalNativeBuild/
android-app/android/.cxx/
*.apk
*.aab
*.keystore
!android-app/android/app/src/main/res/**

# --- Виключення для android-app JSON-файлів ---
!android-app/package.json
!android-app/package-lock.json
!android-app/capacitor.config.json

# Gradle Wrapper — комітити обов'язково
!android-app/android/gradlew
!android-app/android/gradlew.bat
!android-app/android/gradle/
!android-app/android/gradle/wrapper/
!android-app/android/gradle/wrapper/gradle-wrapper.jar
!android-app/android/gradle/wrapper/gradle-wrapper.properties
android-app/package-lock.json
android-app/package.json
android-app/android/capacitor.settings.gradle
android-app/android/gradlew
android-app/android/gradlew.bat
android-app/android/settings.gradle
android-app/android/app/build.gradle
android-app/android/app/capacitor.build.gradle
android-app/android/settings.gradle
android-app/android/app/build.gradle
android-app/android/app/capacitor.build.gradle
android-app/android/gradle/wrapper/gradle-wrapper.jar
android-app/android/gradle/wrapper/gradle-wrapper.properties
android-app/android/capacitor-cordova-android-plugins/cordova.variables.gradle
android-app/android/capacitor-cordova-android-plugins/build.gradle
android-app/android/keystore.properties
android-app/epicservice.keystore
android-app/android/app/build.gradle
